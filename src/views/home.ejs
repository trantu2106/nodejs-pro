<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
  </head>
  <body>
    <div style="margin: 25px">
      <div
        style="
          display: flex;
          justify-content: space-between;
          align-items: center;
        "
      >
        <h1 style="color: blue">List Users:</h1>
        <div>
          <a href="/create-user" class="btn btn-warning">Create a new user</a>
        </div>
      </div>
      <hr />
      <div>
        <table class="table table-hover table-bordered">
          <thead>
            <th>ID</th>
            <th>NAME</th>
            <th>EMAIL</th>
            <th>ADDRESS</th>
            <th>ACTION</th>
          </thead>
          <tbody>
            <% users.forEach( function (user) { %>
            <tr>
              <td><%= user.id %></td>
              <td><%= user.name %></td>
              <td><%= user.email %></td>
              <td><%= user.address %></td>

              <td>
                <div style="display: flex; gap: 10px">
                  <form action="/handle-view-user/<%= user.id %>" method="get">
                    <button type="submit" class="btn btn-warning">View</button>
                  </form>
                  <form
                    action="/handle-delete-user/<%= user.id %>"
                    method="post"
                  >
                    <button type="submit" class="btn btn-danger">Delete</button>
                  </form>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
